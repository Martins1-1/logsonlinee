# server/.env.example

# Server
PORT=5002
JWT_SECRET=your-jwt-secret-here
MONGODB_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# Payments
ECRS_SECRET_KEY=your-ercaspay-live-key-here
PAYSTACK_SECRET=your-paystack-secret-here

# Frontend (used for CORS + password reset links)
FRONTEND_URL=http://localhost:5173

# Email provider (recommended on hosts that block SMTP): Resend
# Set EMAIL_PROVIDER=resend and RESEND_API_KEY to use Resend API.
EMAIL_PROVIDER=resend
RESEND_API_KEY=your-resend-api-key
# Must be a sender address on your verified domain
EMAIL_FROM=LOGs Online <no-reply@your-domain.com>

# SMTP (Namecheap Private Email typically uses mail.privateemail.com)
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-mailbox@your-domain.com
SMTP_PASS=your-email-password
SMTP_FROM=your-mailbox@your-domain.com
SMTP_FROM_NAME=LOGs Online

# Optional: SMTP timeouts (ms)
SMTP_TIMEOUT_MS=10000